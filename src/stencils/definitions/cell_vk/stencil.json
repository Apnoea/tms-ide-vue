{
  "id": "cell_vk",
  "label": "Выключатель",
  "category": "Коммутация",
  "version": "0.2.0",

  "tagPattern": "^PS\\d+\\w+\\d+$",
  "tagSuffixes": [
    { "suffix": ".ONOFF", "type": "Boolean", "required": true }
  ],

  "shapeFile": "shape.svg",
  "width": 20,
  "height": 20,
  "ports": [
    { "name": "top",    "x": 10, "y": 0,  "type": "io" },
    { "name": "right",  "x": 20, "y": 10, "type": "io" },
    { "name": "bottom", "x": 10, "y": 20, "type": "io" },
    { "name": "left",   "x": 0,  "y": 10, "type": "io" }
  ],

  "animationTemplate": [
    {
      "idSuffix": ".VK",
      "type": "shape",
      "bindings": [
        {
          "tag": "{prefix}.ONOFF",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-off" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{prefix}.ONOFF" }]
    },
    {
      "idSuffix": ".VK-cross",
      "type": "shape",
      "bindings": [
        {
          "tag": "{prefix}.ONOFF",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{prefix}.ONOFF" }]
    }
  ]
}
