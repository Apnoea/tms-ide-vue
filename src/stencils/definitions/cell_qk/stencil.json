{
  "id": "cell_qk",
  "label": "Короткозамыкатель",
  "category": "Коммутация",

  "slots": [
    {
      "key": "onoff",
      "label": "Основной выключатель",
      "type": "Boolean",
      "required": false,
      "tagSuffix": ".ONOFF"
    }
  ],

  "shapeFile": "shape.svg",
  "width": 20,
  "height": 40,
  "ports": [{ "name": "top", "x": 10, "y": 0, "type": "io" }],

  "animationTemplate": [
    {
      "idSuffix": ".QK-closed",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.onoff}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.onoff}" }]
    },
    {
      "idSuffix": ".QK-open",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.onoff}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "true": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.onoff}" }]
    }
  ]
}
