{
  "id": "cell_rzv",
  "label": "РЗВ (заземление)",
  "category": "Коммутация",
  "version": "0.1.0",

  "tagPattern": "^PS\\d+\\w+\\d+$",
  "tagSuffixes": [
    { "suffix": ".ONOFF", "type": "Boolean", "required": true }
  ],

  "shapeFile": "shape.svg",
  "width": 40,
  "height": 30,
  "ports": [
    { "name": "right", "x": 40, "y": 15, "type": "io" }
  ],

  "animationTemplate": [
    {
      "idSuffix": ".RZV",
      "type": "shape",
      "bindings": [
        {
          "tag": "{prefix}.ONOFF",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-off" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{prefix}.ONOFF" }]
    },
    {
      "idSuffix": ".RZV-closed",
      "type": "shape",
      "bindings": [
        {
          "tag": "{prefix}.ONOFF",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{prefix}.ONOFF" }]
    },
    {
      "idSuffix": ".RZV-open",
      "type": "shape",
      "bindings": [
        {
          "tag": "{prefix}.ONOFF",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "true": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{prefix}.ONOFF" }]
    }
  ]
}
