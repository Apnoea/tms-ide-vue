{
  "id": "cell_alr",
  "label": "Аварийный сигнал",
  "category": "Сигналы",
  "version": "0.2.0",

  "slots": [
    {
      "key": "alr",
      "label": "Состояние аварии",
      "type": "Boolean",
      "required": true,
      "tagSuffix": ".ALR"
    }
  ],

  "shapeFile": "shape.svg",
  "width": 40,
  "height": 36,
  "ports": [],

  "animationTemplate": [
    {
      "idSuffix": ".ALR",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.alr}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.alr}" }]
    }
  ]
}
