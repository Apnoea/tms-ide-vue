{
  "id": "cell_qw",
  "label": "Выключатель",
  "category": "Коммутация",
  "intrinsicOnoff": true,

  "slots": [
    {
      "key": "onoff",
      "label": "Основной выключатель",
      "type": "Boolean",
      "required": true,
      "tagSuffix": ".ONOFF"
    }
  ],

  "shapeFile": "shape.svg",
  "width": 20,
  "height": 20,
  "ports": [
    { "name": "top", "x": 10, "y": 0 },
    { "name": "right", "x": 20, "y": 10 },
    { "name": "bottom", "x": 10, "y": 20 },
    { "name": "left", "x": 0, "y": 10 }
  ],

  "animationTemplate": [
    {
      "idSuffix": ".QW",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.onoff}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-off" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.onoff}" }]
    },
    {
      "idSuffix": ".QW-cross",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.onoff}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.onoff}" }]
    }
  ]
}
