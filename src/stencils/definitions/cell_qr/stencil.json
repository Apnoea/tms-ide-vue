{
  "id": "cell_qr",
  "label": "Отделитель",
  "category": "Коммутация",
  "quality": true,

  "slots": [
    {
      "key": "onoff",
      "label": "Основной выключатель",
      "type": "Boolean",
      "required": false
    }
  ],

  "shapeFile": "shape.svg",
  "width": 20,
  "height": 40,
  "ports": [
    { "name": "top", "x": 10, "y": 0 },
    { "name": "bottom", "x": 10, "y": 40 }
  ],

  "animationTemplate": [
    {
      "idSuffix": ".closed",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.onoff}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "false": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.onoff}" }]
    },
    {
      "idSuffix": ".open",
      "type": "shape",
      "bindings": [
        {
          "tag": "{slot.onoff}",
          "when": {
            "source": "value",
            "type": "map",
            "cases": {
              "true": { "apply": { "addClass": "animation-hidden" } }
            }
          }
        }
      ],
      "detailTags": [{ "tag": "{slot.onoff}" }]
    }
  ]
}
